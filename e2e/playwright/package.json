{
  "name": "botas-e2e-playwright",
  "version": "0.1.0",
  "private": true,
  "description": "Playwright E2E tests for botas bots running in Teams",
  "scripts": {
    "setup": "npx playwright test --project=auth-setup --headed",
    "test": "npx playwright test --project=dotnet-tests --project=node-tests --project=python-tests",
    "test:headed": "npx playwright test --project=dotnet-tests --project=node-tests --project=python-tests --headed",
    "test:dotnet": "npx playwright test --project=dotnet-tests",
    "test:node": "npx playwright test --project=node-tests",
    "test:python": "npx playwright test --project=python-tests"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "dotenv": "^16.4.7"
  }
}
